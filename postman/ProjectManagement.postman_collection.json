{
  "info": {
    "_postman_id": "pms-backend-api-v1",
    "name": "Project Management System API",
    "description": "Complete REST API collection for the Project Management System.\n\n**Base URL:** `http://localhost:8000/api/v1`\n\n**Authentication:** Bearer Token (Sanctum)\n\nAfter login, copy the `access_token` from the response and set it in the collection variable `token`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000/api/v1", "type": "string" },
    { "key": "token",    "value": "", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/auth/register", "host": ["{{base_url}}"], "path": ["auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Admin\",\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\",\n  \"password_confirmation\": \"password123\",\n  \"phone\": \"+1-555-0100\",\n  \"role\": \"admin\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data && json.data.access_token) {",
                  "  pm.collectionVariables.set('token', json.data.access_token);",
                  "  console.log('Token saved:', json.data.access_token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin1@pms.local\",\n  \"password\": \"password\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Get Current User (Me)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/auth/me", "host": ["{{base_url}}"], "path": ["auth", "me"] }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/auth/logout", "host": ["{{base_url}}"], "path": ["auth", "logout"] }
          }
        }
      ]
    },
    {
      "name": "Projects",
      "item": [
        {
          "name": "List Projects",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/projects?search=&page=1&per_page=15",
              "host": ["{{base_url}}"],
              "path": ["projects"],
              "query": [
                { "key": "search",   "value": "" },
                { "key": "page",     "value": "1" },
                { "key": "per_page", "value": "15" }
              ]
            }
          }
        },
        {
          "name": "Get Project by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/projects/1", "host": ["{{base_url}}"], "path": ["projects", "1"] }
          }
        },
        {
          "name": "Create Project (Admin Only)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/projects", "host": ["{{base_url}}"], "path": ["projects"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"New Project\",\n  \"description\": \"This is a new project description.\",\n  \"start_date\": \"2025-01-01\",\n  \"end_date\": \"2025-12-31\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Update Project (Admin Only)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/projects/1", "host": ["{{base_url}}"], "path": ["projects", "1"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Project Title\",\n  \"description\": \"Updated description.\",\n  \"end_date\": \"2025-11-30\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Delete Project (Admin Only)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/projects/1", "host": ["{{base_url}}"], "path": ["projects", "1"] }
          }
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "List Tasks for Project",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/projects/1/tasks?status=&search=&page=1&per_page=15",
              "host": ["{{base_url}}"],
              "path": ["projects", "1", "tasks"],
              "query": [
                { "key": "status",   "value": "", "description": "pending | in-progress | done" },
                { "key": "search",   "value": "" },
                { "key": "page",     "value": "1" },
                { "key": "per_page", "value": "15" }
              ]
            }
          }
        },
        {
          "name": "Get Task by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/tasks/1", "host": ["{{base_url}}"], "path": ["tasks", "1"] }
          }
        },
        {
          "name": "Create Task (Manager/Admin Only)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/projects/1/tasks", "host": ["{{base_url}}"], "path": ["projects", "1", "tasks"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Implement Feature X\",\n  \"description\": \"Build the X feature with tests.\",\n  \"status\": \"pending\",\n  \"due_date\": \"2025-06-30\",\n  \"assigned_to\": 7\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Update Task (Manager or Assigned User)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/tasks/1", "host": ["{{base_url}}"], "path": ["tasks", "1"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"in-progress\",\n  \"title\": \"Updated Task Title\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Delete Task (Manager/Admin Only)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/tasks/1", "host": ["{{base_url}}"], "path": ["tasks", "1"] }
          }
        }
      ]
    },
    {
      "name": "Comments",
      "item": [
        {
          "name": "List Comments for Task",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/tasks/1/comments", "host": ["{{base_url}}"], "path": ["tasks", "1", "comments"] }
          }
        },
        {
          "name": "Add Comment to Task",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/tasks/1/comments", "host": ["{{base_url}}"], "path": ["tasks", "1", "comments"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"body\": \"This task is progressing well. ETA Friday.\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        }
      ]
    }
  ]
}
